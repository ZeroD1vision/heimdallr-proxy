<file path=".github/workflows/frontend-deploy.yml">
name: "Deploy: Heimdallr Service"

on:
  workflow_dispatch:
  push:
    tags:
      - 'v*.*.*'

permissions:
  contents: read

concurrency:
  group: "deploy-heimdallr"
  cancel-in-progress: true

jobs:
  # ────────────────────────────────────────────────────────────────────────────
  # Job 1: Build Go binary
  # ────────────────────────────────────────────────────────────────────────────
  build-backend:
    name: "Build: Go Binary"
    runs-on: ubuntu-latest

    steps:
      - name: "Source: Checkout Repository"
        uses: actions/checkout@v4

      - name: "Setup: Initialize Go Environment"
        uses: actions/setup-go@v5
        with:
          go-version: '1.25.x'
          cache: true

      - name: "Test: Backend Unit Build Check"
        run: |
          go test ./cmd/... ./internal/...

      - name: "Build: Compile Static Binary"
        # -trimpath удаляет локальные пути разработчика из бинарника, -ldflags="-s -w" убирает отладочную информацию для минимизации размера
        run: |
          CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
          go build -trimpath -v -ldflags="-s -w" -o heimdallr ./cmd/heimdallr

      - name: "Artifact: Upload Go Binary"
        uses: actions/upload-artifact@v4
        with:
          name: heimdallr-binary
          path: heimdallr
          retention-days: 1

  # ────────────────────────────────────────────────────────────────────────────
  # Job 2: Build Next.js frontend (Monorepo Workspace)
  # ────────────────────────────────────────────────────────────────────────────
  build-frontend:
    name: "Build: Next.js Static Export"
    runs-on: ubuntu-latest

    steps:
      - name: "Source: Checkout Repository"
        uses: actions/checkout@v4

      - name: "Setup: Node.js"
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: package-lock.json

      - name: "Install: npm Dependencies"
        run: npm ci --ignore-scripts

      - name: "Build: Static Export → out/"
        run: npm run build -w web/ui

      - name: "Check: out directory exists"
        run: test -d web/ui/out

      - name: "Artifact: Upload Static Files"
        uses: actions/upload-artifact@v4
        with:
          name: frontend-static
          path: web/ui/out/
          retention-days: 1

  # ────────────────────────────────────────────────────────────────────────────
  # Job 3: Deliver artifacts to server
  # ────────────────────────────────────────────────────────────────────────────
  build-and-delivery:
    name: "Delivery: Transfer to Server"
    runs-on: ubuntu-latest
    needs: [build-backend, build-frontend]

    steps:
      - name: "Artifact: Download Go Binary"
        uses: actions/download-artifact@v4
        with:
          name: heimdallr-binary

      - name: "Artifact: Download Frontend Static"
        uses: actions/download-artifact@v4
        with:
          name: frontend-static
          path: out/

      - name: "Deploy: Transfer Binary to Server"
        uses: appleboy/scp-action@v0.1.7
        with:
          host:     ${{ secrets.SSH_HOST }}
          username: ${{ secrets.SSH_USER }}
          key:      ${{ secrets.SSH_DEPLOY_USER_KEY }}
          port:     ${{ secrets.SSH_PORT }}
          source:   "heimdallr"
          target:   "/var/www/heimdallr"

      - name: "Deploy: Transfer Frontend Static to Server"
        uses: appleboy/scp-action@v0.1.7
        with:
          host:     ${{ secrets.SSH_HOST }}
          username: ${{ secrets.SSH_USER }}
          key:      ${{ secrets.SSH_DEPLOY_USER_KEY }}
          port:     ${{ secrets.SSH_PORT }}
          source:   "out/"
          target:   "/var/www/heimdallr"
          # Результат: /var/www/heimdallr/out/ — совпадает с STATIC_DIR в .env

  # ────────────────────────────────────────────────────────────────────────────
  # Job 4: Service orchestration
  # ────────────────────────────────────────────────────────────────────────────
  service-orchestration:
    name: "Service Management"
    runs-on: ubuntu-latest
    needs: build-and-delivery

    steps:
      - name: "Systemd: Restart Heimdallr Service"
        uses: appleboy/ssh-action@v1.0.3
        with:
          host:     ${{ secrets.SSH_HOST }}
          username: ${{ secrets.SSH_USER }}
          key:      ${{ secrets.SSH_DEPLOY_USER_KEY }}
          port:     ${{ secrets.SSH_PORT }}
          script: |
            set -euo pipefail
            sudo chmod +x /var/www/heimdallr/heimdallr
            sudo systemctl restart heimdallr.service

      - name: "Healthcheck: Verify Service Status"
        uses: appleboy/ssh-action@v1.0.3
        with:
          host:     ${{ secrets.SSH_HOST }}
          username: ${{ secrets.SSH_USER }}
          key:      ${{ secrets.SSH_DEPLOY_USER_KEY }}
          port:     ${{ secrets.SSH_PORT }}
          script: |
            sudo systemctl is-active --quiet heimdallr.service || exit 1

      - name: "Healthcheck: API Smoke Test"
        uses: appleboy/ssh-action@v1.0.3
        with:
          host:     ${{ secrets.SSH_HOST }}
          username: ${{ secrets.SSH_USER }}
          key:      ${{ secrets.SSH_DEPLOY_USER_KEY }}
          port:     ${{ secrets.SSH_PORT }}
          script: |
            # Проверяем что / отдаёт 200 (Next.js index.html через Echo)
            curl -fsS --retry 10 --retry-delay 2 http://localhost:${{ secrets.API_PORT }}/ -o /dev/null || exit 1
            echo "Frontend serving: OK"
</file>

